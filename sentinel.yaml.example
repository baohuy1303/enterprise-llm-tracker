listen: ":8081"

postgres:
  url: "postgres://sentinel:sentinel@localhost:5433/sentinel?sslmode=disable"

redis:
  addr: "localhost:6379"

kafka:
  brokers: ["localhost:9092"]
  topic: "claude.usage.events"
  consumer_group_prefix: "sentinel"

github:
  # For a GitHub organization: set org to the org name, omit is_user (defaults false).
  # For a personal account: set org to your GitHub username and is_user: true.
  org: "mycompany"
  # is_user: true
  repos:
    - "mycompany/backend"
    - "mycompany/frontend"
  token_env: "GITHUB_TOKEN"     # env var holding your PAT (needs `repo` scope)
  lookback_days: 30             # how far back the PR fetcher pages; use 180 for historical data
  scheduler:
    interval_seconds: 3600           # hourly safety net cron tick
    min_trigger_interval_seconds: 300 # debounce Kafka-driven refreshes to once per 5 min

slack:
  bot_token_env: "SLACK_BOT_TOKEN"
  default_manager_channel: "#eng-leadership"

thresholds:
  notify_at_percent: [80, 100]
  notify_manager_at_percent: [100]

registry:
  refresh_interval_seconds: 30

admin:
  token_env: "ADMIN_TOKEN"     # env var holding the bearer token for /admin/* endpoints

# Signal analytics: efficiency rollups + real-time pattern detection
# (burst spend, daily-spend Z-score, rhythm break). Detector runs as a Kafka
# consumer in sentinel-workers; rollups + baselines run as nightly cron jobs.
signals:
  baseline_rebuild_interval_seconds: 86400   # nightly rebuild of per-engineer baselines
  efficiency_rollup_interval_seconds: 86400  # nightly aggregation into engineer_signals
  baseline_window_days: 30                   # daily spend mean/stddev lookback
  hourly_baseline_window_days: 14            # hourly p95 lookback for burst detection
  min_baseline_days: 14                      # suppress detection for engineers with less history
  burst_window_minutes: 30
  burst_multiplier: 2.0                      # warn at 2x hourly p95, critical at 3x
  zscore_warn: 2.0                           # daily spend > 2σ above mean = warn
  zscore_critical: 3.0
  rhythm_break_pct: 0.05                     # hour-of-day bucket holding <5% of activity = rhythm break
  notify_burst_critical: true                # DM engineer + manager on burst-critical
