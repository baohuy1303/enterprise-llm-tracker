# Stage 1: build
FROM golang:1.26-alpine AS builder
WORKDIR /build

# Copy dependecies so that we can leverage docker cache
COPY go.mod go.sum ./
RUN go mod download

# Copy rest of the files
# (this won't trigger redownload of dependecies)
COPY . .

# Build the binary and remove all the extra debugging symbols
# Leaving only the essential data
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /sentinel-api ./cmd/sentinel-api

# Stage 2: minimal runtime — no shell, no package manager
FROM gcr.io/distroless/static-debian12
WORKDIR /app

# Binary
COPY --from=builder /sentinel-api /app/sentinel-api
# Migrations run on API startup; embed them at a known path.
COPY migrations/ /app/migrations/

ENV SENTINEL_MIGRATIONS_DIR=/app/migrations

EXPOSE 8081
ENTRYPOINT ["/app/sentinel-api"]
