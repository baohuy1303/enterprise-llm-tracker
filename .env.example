# Copy to .env and fill in real values. .env is gitignored.

# Slack Bot User OAuth Token (starts with xoxb-).
# Required for sentinel-workers to send threshold DMs.
# Get it from https://api.slack.com/apps → your app → OAuth & Permissions.
SLACK_BOT_TOKEN=xoxb-...

# GitHub personal access token (classic or fine-grained).
# Required for sentinel-workers GitHub collector (Stage 7).
# Needs `repo` scope (or `public_repo` for public-only repos).
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Bearer token for /admin/* endpoints (Stage 7+).
# Pick any long random string — clients must send `Authorization: Bearer <token>`.
ADMIN_TOKEN=replace-with-a-long-random-string
